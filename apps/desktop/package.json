{
    "name": "@rc/desktop",
    "version": "0.1.0",
    "private": true,
    "description": "rc macOS desktop control panel (Electron shell)",
    "main": "dist/main/index.js",
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "dev": "bun run build && env -u ELECTRON_RUN_AS_NODE RC_BINARY=\"$PWD/../../bin/rc\" electron .",
        "typecheck": "tsc -p tsconfig.json --noEmit",
        "test": "vitest run --config vitest.config.ts",
        "lint": "bunx oxlint src",
        "package": "bun run build && electron-builder --mac --universal"
    },
    "devDependencies": {
        "@types/node": "^22.15.30",
        "electron": "^42.0.0",
        "electron-builder": "^26.0.12",
        "oxlint": "^1.60.0",
        "typescript": "^6.0.2",
        "vitest": "^4.1.0"
    }
}
