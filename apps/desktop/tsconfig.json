{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "module": "CommonJS",
        "moduleResolution": "node10",
        "ignoreDeprecations": "6.0",
        "verbatimModuleSyntax": false,
        "outDir": "dist",
        "rootDir": "src",
        "composite": true
    },
    "include": ["src/**/*"],
    "exclude": ["node_modules", "dist"]
}
