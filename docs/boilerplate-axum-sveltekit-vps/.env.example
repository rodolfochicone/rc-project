# Domínio público (Caddy TLS). Em dev local deixe localhost.
DOMAIN=localhost

# Postgres
POSTGRES_USER=app
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=app
DATABASE_URL=postgres://app:troque-esta-senha@127.0.0.1:5432/app

# Axum
API_HOST=127.0.0.1
API_PORT=3000
RUST_LOG=app_api=info,tower_http=info

# SvelteKit (servidor)
PORT=3001
HOST=127.0.0.1
# URL interna usada no SSR (server → api na mesma máquina)
API_INTERNAL_URL=http://127.0.0.1:3000

# Públicas (build-time / browser). Em produção atrás do Caddy, deixe vazio
# para o front usar same-origin (/api e /ws via proxy).
PUBLIC_API_URL=
PUBLIC_WS_URL=
