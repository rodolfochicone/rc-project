{
    "name": "rc-web",
    "private": true,
    "type": "module",
    "scripts": {
        "codegen": "bun run --cwd .. codegen && node ./scripts/tsr-generate.mjs",
        "codegen-check": "bun run --cwd .. codegen-check && node ./scripts/tsr-generate.mjs",
        "build": "bun run codegen-check && vite build && node ./scripts/restore-dist-placeholder.mjs",
        "dev": "bun run codegen && vite",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "preview": "vite preview",
        "test": "bun run codegen-check && vitest run --config vitest.config.ts",
        "test:e2e": "playwright test --config playwright.config.ts",
        "typecheck": "bun run codegen-check && tsc -p tsconfig.json --noEmit"
    },
    "dependencies": {
        "@ai-sdk/react": "^3.0.170",
        "@assistant-ui/react": "^0.12.26",
        "@assistant-ui/react-ai-sdk": "^1.3.20",
        "@rodolfochicone/ui": "workspace:*",
        "@tanstack/react-query": "^5.99.0",
        "@tanstack/react-router": "^1.168.22",
        "@tanstack/react-virtual": "^3.13.24",
        "ai": "^6.0.168",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "lucide-react": "^1.8.0",
        "openapi-fetch": "^0.17.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.0",
        "zustand": "^5.0.11"
    },
    "devDependencies": {
        "@playwright/test": "^1.55.0",
        "@storybook/addon-a11y": "^10.3.5",
        "@storybook/addon-docs": "^10.3.5",
        "@storybook/addon-themes": "^10.3.5",
        "@storybook/react-vite": "^10.3.5",
        "@tailwindcss/vite": "^4.2.3",
        "@tanstack/react-query-devtools": "^5.99.0",
        "@tanstack/react-router-devtools": "^1.166.13",
        "@tanstack/router-generator": "^1.166.32",
        "@tanstack/router-plugin": "^1.167.22",
        "@testing-library/jest-dom": "^6.9.1",
        "@testing-library/react": "^16.3.0",
        "@testing-library/user-event": "^14.6.1",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^6.0.0",
        "jsdom": "^27.1.0",
        "msw": "^2.13.4",
        "msw-storybook-addon": "^2",
        "openapi-typescript": "^7.9.1",
        "storybook": "^10.3.5",
        "tailwindcss": "^4.2.3"
    }
}
