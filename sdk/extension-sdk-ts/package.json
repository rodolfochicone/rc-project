{
    "name": "@rodolfochicone/extension-sdk",
    "version": "0.1.10",
    "description": "TypeScript SDK for rc executable extensions",
    "license": "MIT",
    "files": [
        "dist",
        "templates",
        "README.md"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing/index.d.ts",
            "import": "./dist/testing/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    },
    "engines": {
        "node": ">=18"
    }
}
