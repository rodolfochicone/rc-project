{
    "name": "@rodolfochicone/create-extension",
    "version": "0.1.10",
    "description": "Scaffold rc extension projects",
    "license": "MIT",
    "bin": {
        "create-extension": "./dist/bin/create-extension.js"
    },
    "files": [
        "dist",
        "README.md"
    ],
    "type": "module",
    "exports": {
        ".": {
            "types": "./dist/src/index.d.ts",
            "import": "./dist/src/index.js"
        },
        "./package.json": "./package.json"
    },
    "scripts": {
        "build": "tsc -p tsconfig.json && node ./scripts/copy-templates.mjs",
        "typecheck": "tsc -p tsconfig.json --noEmit"
    }
}
